# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/

# Virtual envs (we use conda, but defensive)
venv/
.venv/
.env

# IDE
.vscode/
.idea/
*.code-workspace

# Attached images saved by tools (e.g. Claude Code dropping screenshots into
# the repo root). Local scratch only, never tracked.
Images/
images/

# OS
Thumbs.db
.DS_Store

# Project data (keep folder, ignore contents)
data/*
!data/.gitkeep
# DO commit the validation results so VALIDATION.md links resolve from
# a fresh clone -- they are small, human-readable, and dropping them
# with every push would break the "see the numbers I cite" promise.
!data/validation/
data/validation/*_log*.txt
# 3D sphere drag validation (read by tests/test_validation_3d_sphere_cd.py;
# regenerate via scripts/validate_3d_sphere_cd.py).
!data/validation_3d_sphere_re100.json
# Low-blockage variant on a 160 x 80 x 80 grid (B = 25 %), read by
# tests/test_validation_3d_sphere_cd_lowblock.py; regenerate via
# scripts/validate_3d_sphere_cd_lowblock.py.
!data/validation_3d_sphere_re100_lowblock.json
# Re = 20 steady-wake companion (audit item #9 from v1.6.5.1), read by
# tests/test_validation_3d_sphere_cd_stokes_regime.py; regenerate via
# scripts/validate_3d_sphere_cd_stokes_regime.py.
!data/validation_3d_sphere_re20_stokes_regime.json
# D = 40 sphere bake (audit item #8 first half, v1.6.5.1), read by
# tests/test_validation_3d_sphere_cd_d40.py; regenerate via
# scripts/validate_3d_sphere_cd_d40.py.
!data/validation_3d_sphere_re100_d40.json
# D = 40 sphere bake with MYSL 2002 momentum exchange (audit item #8
# second half, v1.7.0), read by
# tests/test_validation_3d_sphere_cd_mysl_d40.py; regenerate via
# scripts/validate_3d_sphere_cd_mysl_d40.py.
!data/validation_3d_sphere_re100_d40_mysl.json
# Re = 20 method-consistent MYSL + D = 40 sphere bake (audit Task 7 of
# 2026-06-01 forensic re-audit, §8.3.5), read by
# tests/test_validation_3d_sphere_cd_stokes_regime_mysl_d40.py;
# regenerate via scripts/validate_3d_sphere_cd_stokes_regime_mysl_d40.py.
!data/validation_3d_sphere_re20_mysl_d40.json
# DO commit pre-baked 3D fields. Cloud has no GPU and runs the
# 3D LBM kernel as a Numba serial loop -- the gallery's whole value
# prop is consumer-mode replay of a pre-baked steady-state field, so
# the .npz files are the SHIPPED ARTIFACT. They're float16-quantised
# and small (~300 KB for sphere_re40 at 64x32x32). Re-baking via
# scripts/bake_3d_field.py produces a different ts_baked stamp inside
# the manifest (and zip-archive metadata timestamps), so a re-bake
# will show as modified in git -- that is intended, revert with
# `git restore data/baked/<name>.npz` if the re-bake wasn't meant to
# update the shipped artifact.
!data/baked/

# Local venvs created by uv / pyenv for solver-local execution.
# Project CI + Cloud deploy use requirements.txt, so these are local-only.
.venv*/

# Bake logs from overnight runs. Pinned per-bake stdout / stderr
# captures (e.g. log.d40.txt, log.d40.err.txt) are local debugging
# artifacts -- the JSON results in data/validation*.json are the
# committed record.
log.*.txt
log.*.err.txt
