FoamFile
{
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     foamRun;

solver          incompressibleFluid;

// Comprehensive run targeting Williamson 1996 to ±5 %. Mesh refined
// per-block + simpleGrading clustering cells near the cylinder, and
// fvSchemes div(phi,U) switched from Gauss linear to linearUpwindV
// (less numerical diffusion). endTime = 1000 = 500 D/U: past startup
// (~150 D/U) + ~350 D/U of fully-saturated shedding for clean Cd
// mean and St FFT.
startFrom       startTime;

startTime       0;

stopAt          endTime;

endTime         1000;

// dt = 0.005 keeps CFL < 0.5 in the finest cells near the cylinder
// (graded mesh first cell ~0.014, U_max ~ 1.5 in the throat).
deltaT          0.005;

writeControl    runTime;

// Write fields every 10 D/U for visual sanity checks during the run.
writeInterval   10;

purgeWrite      0;

writeFormat     ascii;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable true;

// Force-coefficient time series. Written every time step into
// postProcessing/forceCoeffs/0/forceCoeffs.dat -- read by
// validation/compare_aerolab_vs_openfoam.py.
//
// rho = 1 (incompressible normalisation), |U_Inf| = 1, l_Ref = D = 2,
// A_Ref = D * span = 2 * 2 = 4. CofR is the cylinder axis.
functions
{
    forceCoeffs
    {
        type            forceCoeffs;
        libs            ("libforces.so");
        writeControl    timeStep;
        writeInterval   1;

        patches         (cylinder);

        rho             rhoInf;
        rhoInf          1;

        liftDir         (0 1 0);
        dragDir         (1 0 0);
        pitchAxis       (0 0 1);

        magUInf         1;
        lRef            2;
        Aref            4;

        CofR            (0 0 0);
    }
}


